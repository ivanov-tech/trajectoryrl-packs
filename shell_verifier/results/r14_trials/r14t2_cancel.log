"""Async task runner with bounded concurrency and graceful interrupt handling."""

import asyncio
from typing import Callable, Awaitable


async def run_tasks(
    tasks: list[Callable[[], Awaitable[None]]],
    max_concurrent: int,
) -> None:
    """
    Run async tasks with bounded concurrency.
    
    Each task is a callable returning an awaitable. Tasks are pulled from a 
    backlog rather than created upfront, ensuring clean interrupt handling:
    - In-flight tasks complete with cleanup
    - Items still in the backlog never start
    
    Args:
        tasks: List of async callables to execute
        max_concurrent: Maximum number of tasks running simultaneously
    """
    if max_concurrent < 1:
        raise ValueError("max_concurrent must be at least 1")
    
    n = len(tasks)
    if n == 0:
        return
    
    semaphore = asyncio.Semaphore(max_concurrent)
    done_count = 0
    done_lock = asyncio.Lock()
    
    async def run_single(task_callable):
        """Run a single task with semaphore and cleanup tracking."""
        try:
            await semaphore.acquire()
            try:
                await task_callable()
            finally:
                # Signal completion
                async with done_lock:
                    nonlocal done_count
                    done_count += 1
        except asyncio.CancelledError:
            raise
        except Exception:
            # Task failed, but we still count it
            async with done_lock:
                nonlocal done_count


import asyncio
from typing import Callable, Awaitable, Set


async def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
    """Run async tasks with a maximum number of concurrent tasks.
    
    Args:
        tasks: List of async callables (each returning Awaitable[None])
        max_concurrent: Maximum number of tasks to run concurrently
    
    The cleanup code in tasks will run even if the run is interrupted.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    pending: Set[asyncio.Task] = set()
    
    async def worker(task: Callable[[], Awaitable[None]]) -> None:
        await task()
    
    for task in tasks:
        # Acquire semaphore first before creating the task
        await semaphore.acquire()
        t = asyncio.create_task(worker(task))
        pending.add(t)
        t.add_done_callback(lambda _: semaphore.release())
        t.add_done_callback(pending.discard)
    
    try:
        await asyncio.gather(*pending)
    except asyncio.CancelledError:
        # Cancel all remaining tasks to allow their cleanup code to run
        for t in list(pending):
            t.cancel()
        # Wait for cancelled tasks to complete
        await asyncio.gather(*pending, return_exceptions=True)
        raise


import asyncio
from typing import Callable, Awaitable


async def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
    """Run async tasks with maximum concurrency.
    
    Args:
        tasks: List of async callables to run
        max_concurrent: Maximum number of tasks to run concurrently
    
    Ensures cleanup code runs even on KeyboardInterrupt.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    
    inner_tasks: dict[int, asyncio.Task] = {}
    task_counter = [0]
    running: list[asyncio.Task] = []
    
    async def run_one(task: Callable[[], Awaitable[None]]) -> None:
        idx = task_counter[0]
        task_counter[0] += 1
        await semaphore.acquire()
        try:
            inner_tasks[idx] = asyncio.create_task(task())
            await inner_tasks[idx]
        finally:
            semaphore.release()
    
    try:
        for task in tasks:
            t = asyncio.create_task(run_one(task))
            running.append(t)
            t.add_done_callback(lambda _: running.remove(t) if t in running else None)
            
            # If at max capacity, wait for one to finish
            while len(running) >= max_concurrent:
                done, _ = await asyncio.wait(running, return_when=asyncio.FIRST_COMPLETED)
    
    except KeyboardInterrupt:
        # Cancel all inner tasks
        for inner in inner_tasks.values():
            inner.cancel()
        # Wait for cleanup
        await asyncio.gather(*inner_tasks.values(), return_exceptions=True)
        # Also cancel wrappers
        for t in running:
            t.cancel()
        await asyncio.gather(*running, return_exceptions=True)
        raise


import asyncio
from collections import deque
from typing import Callable, Awaitable


async def run_tasks(
    tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int
) -> None:
    """Run async tasks with limited concurrency.

    Args:
        tasks: List of async callables to run.
        max_concurrent: Maximum number of tasks to run concurrently.

    The function handles KeyboardInterrupt gracefully, ensuring cleanup
    code in tasks still runs before exiting.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    pending = set()

    async def run_task(task):
        async with semaphore:
            task_coro = task()
            try:
                await task_coro
            finally:
                # Ensures cleanup runs even if task raises
                pass

    try:
        for task in tasks:
            pending.add(asyncio.create_task(run_task(task)))

        if pending:
            done, _ = await asyncio.wait(pending, return_when=asyncio.FIRST_EXCEPTION)
    except KeyboardInterrupt:
        # Cancel all pending tasks on interrupt
        for task in pending:
            task.cancel()
        # Wait for all cancellations to complete (cleanup runs in finally blocks)
        if pending:
            await asyncio.gather(*pending, return_exceptions=True)
        raise


import asyncio
from typing import Callable, Awaitable


async def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
    """Run async tasks with limited concurrency, ensuring cleanup runs on interrupt.
    
    Args:
        tasks: List of async callables (no-args) to execute.
        max_concurrent: Maximum number of tasks to run concurrently.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    
    async def run_with_cleanup(task_func):
        async with semaphore:
            try:
                await task_func()
            finally:
                # Cleanup runs regardless of how task completes
                pass
    
    # Create all task coroutines first
    pending = [asyncio.create_task(run_with_cleanup(t)) for t in tasks]
    
    try:
        # Wait for all tasks to complete
        await asyncio.gather(*pending, return_exceptions=True)
            
    except asyncio.CancelledError:
        # Handle keyboard interrupt - cancel remaining tasks and wait for cleanup
        for task in pending:
            if not task.done():
                task.cancel()
        
        # Wait for all tasks to finish (allowing cleanup in finally blocks)
        await asyncio.gather(*pending, return_exceptions=True)
        raise


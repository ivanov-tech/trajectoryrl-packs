import asyncio
from typing import Callable, Awaitable, Any


async def run_tasks(tasks: list[Callable[[], Awaitable[Any]]], max_concurrent: int) -> None:
    """
    Run async tasks with a maximum concurrency limit.
    
    Args:
        tasks: List of async callables (each returning Awaitable[Any])
        max_concurrent: Maximum number of tasks to run concurrently
    
    Handles keyboard interrupt gracefully - cleanup code in tasks will still run.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    
    async def run_task_with_sem(task: Callable[[], Awaitable[Any]]) -> None:
        async with semaphore:
            await task()
    
    # Create wrapper coroutines for each task
    coros = [run_task_with_sem(task) for task in tasks]
    
    try:
        await asyncio.gather(*coros)
    except asyncio.CancelledError:
        # Cancel all remaining tasks and wait for them to complete (running cleanup)
        for coro in coros:
            if not coro.done():
                coro.cancel()
        # Wait for all cancelled tasks to finish their cleanup
        if coros:
            await asyncio.gather(*coros, return_exceptions=True)
        raise


import asyncio
from collections.abc import Awaitable, Callable
from contextlib import asynccontextmanager


@asynccontextmanager
async def limiter(max_concurrent: int):
    """A context manager that limits concurrent operations."""
    semaphore = asyncio.Semaphore(max_concurrent)
    try:
        async with semaphore:
            yield
    finally:
        pass


async def run_tasks(
    tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int
) -> None:
    """
    Run async tasks with a maximum number of concurrent executions.
    
    Each task is a callable that returns an Awaitable. Tasks are run
    concurrently up to max_concurrent at a time. On KeyboardInterrupt,
    pending tasks are cancelled and cleanup code runs.
    
    Args:
        tasks: List of async task callables (each takes no args, returns Awaitable)
        max_concurrent: Maximum number of tasks to run concurrently
    """
    pending: list[asyncio.Task] = []
    
    try:
        for task in tasks:
            if len(pending) >= max_concurrent:
                # Wait for at least one task to complete
                done, pending = await asyncio.wait(pending, return_when=asyncio.FIRST_COMPLETED)
                # Clear done tasks from the list
                pending = list(pending)
            
            # Start a new task
            pending.append(asyncio.create_task(task()))
        
        # Wait for all remaining tasks
        if pending:
            await asyncio.gather(*pending, return_exceptions=True)
            

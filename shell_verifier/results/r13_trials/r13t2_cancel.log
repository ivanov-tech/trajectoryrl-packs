import asyncio
from collections import deque
from typing import Callable, Awaitable


async def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
    """Run async tasks with a maximum number of concurrent tasks.
    
    Each task is a callable that returns an awaitable (typically an async function).
    Cleanup code in tasks will run even if interrupted via keyboard interrupt.
    
    Args:
        tasks: List of async callable tasks to run.
        max_concurrent: Maximum number of tasks that can run concurrently.
    """
    if not tasks or max_concurrent <= 0:
        return
    
    semaphore = asyncio.Semaphore(max_concurrent)
    pending = deque()
    exceptions: list[Exception] = []
    
    async def run_task(task: Callable[[], Awaitable[None]]) -> None:
        try:
            async with semaphore:
                await task()
        except asyncio.CancelledError:
            raise
        except Exception as e:
            exceptions.append(e)
    
    try:
        for task in tasks:
            pending.append(asyncio.create_task(run_task(task)))
        
        while pending:
            done, pending = await asyncio.wait(
                pending,
                return_when=asyncio.FIRST_COMPLETED
            )
    except KeyboardInterrupt:
        for task in pending:
            task.cancel()
        if pending:
            await asyncio.gather(*pending, return_exceptions=True)
        if exceptions:
            raise exceptions[0]


"""Async task runner with concurrency control and graceful cancellation."""

import asyncio
from collections.abc import Callable, Awaitable


async def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
    """Run async tasks concurrently with a maximum limit.
    
    Each task is called and awaited. Tasks' cleanup code runs even on keyboard interrupt.
    
    Args:
        tasks: List of async functions to run. Each takes no arguments.
        max_concurrent: Maximum number of tasks to run concurrently.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    running_tasks: set[asyncio.Task[None]] = set()
    cancelled = False
    
    async def run_one(task: Callable[[], Awaitable[None]]) -> None:
        nonlocal cancelled
        async with semaphore:
            if cancelled:
                return
            async def wrapper() -> None:
                try:
                    await task()
                except asyncio.CancelledError:
                    raise
            fut = asyncio.create_task(wrapper())
            running_tasks.add(fut)
            try:
                await fut
            finally:
                running_tasks.discard(fut)
    
    try:
        for task in tasks:
            if cancelled:
                break
            await run_one(task)
    except asyncio.CancelledError:
        cancelled = True
        # Cancel all running tasks
        for task in list(running_tasks):
            task.cancel()
        # Wait for all tasks to complete their cleanup
        await asyncio.gather(*running_tasks, return_exceptions=True)
        running_tasks.clear()
        raise


import asyncio
from collections.abc import Awaitable, Callable


async def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
    """Run async tasks with controlled concurrency.
    
    Args:
        tasks: List of async callables to run.
        max_concurrent: Maximum number of tasks to run concurrently.
    """
    semaphore = asyncio.Semaphore(max_concurrent)
    task_futures = []
    
    async def run_with_cleanup(task: Callable[[], Awaitable[None]]) -> None:
        try:
            async with semaphore:
                await task()
        except asyncio.CancelledError:
            raise
        except Exception:
            pass
    
    for task in tasks:
        task_futures.append(asyncio.create_task(run_with_cleanup(task)))
    
    try:
        await asyncio.gather(*task_futures)
    except asyncio.CancelledError:
        for t in task_futures:
            if not t.done():
                t.cancel()
        await asyncio.gather(*task_futures, return_exceptions=True)


import asyncio
from typing import Callable, Awaitable, List


async def run_tasks(
    tasks: List[Callable[[], Awaitable[None]]], max_concurrent: int
) -> None:
    """Run async tasks with a maximum number of concurrent executions.

    Args:
        tasks: A list of async callables (each returns a coroutine when called).
        max_concurrent: Maximum number of tasks to run simultaneously.

    The function ensures cleanup code runs even on KeyboardInterrupt.
    """
    semaphore = asyncio.Semaphore(max_concurrent)

    async def wrapped_task(task: Callable[[], Awaitable[None]]) -> None:
        async with semaphore:
            await task()

    try:
        await asyncio.gather(*[wrapped_task(t) for t in tasks])
    except asyncio.CancelledError:
        pass

